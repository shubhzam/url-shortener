generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Url {
  id          Int       @id @default(autoincrement())
  shortCode   String    @unique
  originalUrl String
  createdAt   DateTime  @default(now())
  expiresAt   DateTime?
  clickCount  Int       @default(0)
}